LLM_PROVIDER=doubao
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your-api-key-here
LLM_MODEL=doubao-seed-2-0-lite-260428
LLM_TIMEOUT_SECONDS=40

DEV_MODE_PASSWORD=your-dev-password

# Player invite gate — single shared code. Leave empty to disable.
# Rotating this value invalidates all existing invite cookies.
INVITE_CODE=

# v1.3/v1.4 backend hardening (optional)
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
SESSION_TTL_MINUTES=30
SESSION_MAX_CONCURRENT=200
SESSION_HARD_MAX_TURNS=50

# v2.0 content persistence (Supabase). Backend-only service role key — never expose to frontend.
# Leave empty to keep reading/writing local scripts/*.json (rollback / offline).
SUPABASE_URL=
SUPABASE_KEY=
# Optional override: file | supabase | empty=auto (supabase when URL+KEY set)
CONTENT_BACKEND=

# v2.0.4 account system (detail-4). Anon public key — safe to expose to frontend for Auth JS SDK.
# Required to enable login / magic link / history features.
SUPABASE_ANON_KEY=
